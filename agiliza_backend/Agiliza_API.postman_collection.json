{
  "info": {
    "name": "Agiliza API Collection",
    "description": "Complete API collection for Agiliza authentication and user management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"password_confirm\": \"SecurePass123!\",\n  \"full_name\": \"New User\",\n  \"phone\": \"+1234567890\",\n  \"role\": \"CLIENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register",
                ""
              ]
            },
            "description": "Register a new user and get JWT tokens"
          },
          "response": []
        },
        {
          "name": "2. Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login",
                ""
              ]
            },
            "description": "Login user and get JWT tokens"
          },
          "response": []
        },
        {
          "name": "3. Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/profile/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "profile",
                ""
              ]
            },
            "description": "Get current authenticated user's profile"
          },
          "response": []
        },
        {
          "name": "4. Update User Profile (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Updated User Name\",\n  \"phone\": \"+9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/profile/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "profile",
                ""
              ]
            },
            "description": "Partially update user profile"
          },
          "response": []
        },
        {
          "name": "5. Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "token",
                "refresh",
                ""
              ]
            },
            "description": "Get a new access token using refresh token"
          },
          "response": []
        },
        {
          "name": "6. Logout User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/logout/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "logout",
                ""
              ]
            },
            "description": "Logout user and blacklist tokens"
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints"
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/auth",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ]
}
